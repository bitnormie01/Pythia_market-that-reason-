{
  "name": "@uniswap/ai-source",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "build": "nx run-many --target=build --all",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "docs:dev": "nx run docs:dev",
    "docs:build": "nx run docs:build",
    "docs:preview": "nx run docs:preview",
    "docs:api": "nx run evals:generate-api-docs",
    "docs:lint": "vale docs/",
    "lint:actions": "actionlint -shellcheck=\"\"",
    "prepare": "node scripts/prepare.cjs",
    "lefthook": "bunx lefthook run pre-commit"
  },
  "private": true,
  "devDependencies": {
    "@anthropic-ai/sdk": "0.72.1",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@nx/devkit": "22.0.2",
    "@nx/eslint": "22.0.2",
    "@nx/eslint-plugin": "22.0.2",
    "@nx/jest": "22.0.2",
    "@nx/js": "22.0.2",
    "@swc-node/register": "1.9.2",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.15.33",
    "@swc/helpers": "0.5.21",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.9",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "gray-matter": "4.0.3",
    "jest": "30.4.2",
    "jest-environment-node": "30.4.1",
    "jsonc-eslint-parser": "2.4.2",
    "lefthook": "1.13.6",
    "markdownlint-cli2": "0.20.0",
    "nx": "22.0.2",
    "prettier": "2.8.8",
    "promptfoo": "0.121.11",
    "ts-jest": "29.4.9",
    "tslib": "2.8.1",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "vitepress": "1.6.4"
  },
  "workspaces": [
    "packages/*",
    "packages/plugins/*",
    "packages/sdk/*"
  ],
  "nx": {
    "includedScripts": []
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "protobufjs": ">=8.0.2",
    "picomatch": ">=4.0.4"
  },
  "trustedDependencies": []
}
